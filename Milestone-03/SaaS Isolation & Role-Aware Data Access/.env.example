# CorpFlow API - Environment Configuration
# Copy this to .env and fill in your details

# Database Connection
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Default local postgres:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/corpflow

# Server configuration
PORT=3000
NODE_ENV=development

# API: every /users and /projects request must include:
#   X-Tenant-Id: <tenant id>
#   X-User-Id: <user id in that tenant>
